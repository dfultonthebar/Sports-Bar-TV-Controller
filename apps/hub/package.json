{
  "name": "@sports-bar/hub",
  "version": "1.0.0",
  "private": true,
  "description": "SBCC central hub — fleet telemetry ingest + monitoring dashboard",
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "echo '[hub] build skipped — SBCC Phase A in progress, not yet wired into the fleet build' && exit 0",
    "build:next": "next build",
    "start": "next start -p 3010",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sports-bar/hub-agent": "*",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.45.0",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "drizzle-kit": "^0.31.5",
    "typescript": "^6.0.0"
  }
}
