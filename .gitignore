.env*.local
.env

# local configuration files
config/*.local.json
config/*.local.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# uploads
/uploads/*
!/uploads/.gitkeep
/public/uploads/*
!/public/uploads/.gitkeep
apps/web/public/uploads/layouts/

# logs
*.log
/logs/*
!/logs/.gitkeep

# AI style analysis
/ai-style-reports/*
