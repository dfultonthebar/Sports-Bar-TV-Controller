/ai-style-backups/*
!/ai-style-backups/.gitkeep

# Database
prisma/*.db
prisma/*.db-journal
data/*.db
data/*.db-journal

# Prisma migration artifacts (using Drizzle ORM now)
*.prisma-backup
prisma/
schema.prisma
migrate-*-to-drizzle.*
*prisma-migration*

# User data files (subscriptions, credentials, device configs)
data/*.json
!data/*.template.json
data/scene-logs/
data/atlas-configs/
apps/web/data/atlas-configs/
apps/web/data/reports/
data/backups/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# pm2
ecosystem.config.js

# backup files
*.bak
*.backup
*.backup.*
*.backup[0-9]*
*.orig
*.old
core

# Git files
FETCH_HEAD

# Use npm only, ignore yarn
yarn.lock

# Build artifacts and temporary files
benchmark-reports/
next/
**/dist/
*.tgz
*.tar.gz
!**/backups/*.tar.gz
.env.backup*

# Memory Bank snapshots
/memory-bank/*
!/memory-bank/.gitkeep
rag-data/

# Large log files
/log/

# FireStick Scout build artifacts
# Android build outputs (firestick-scout)
firestick-scout/.gradle/
firestick-scout/gradle-dist/
firestick-scout/gradle.zip
firestick-scout/app/build/
firestick-scout/build/
firestick-scout/local.properties
firestick-scout/*.apk
firestick-scout/app/release/
firestick-scout/app/debug/

# Binary blobs — never commit these
*.apk
*.zip
*.sqlite
*.sqlite-journal
*.db-journal
database_backups/

# Claude Code session-local settings (per-user, never ship on main)
.claude/settings.local.json

# Playwright screenshots (regenerated during testing)
playwright-screenshots/
.playwright-mcp/

# Turborepo
.turbo
