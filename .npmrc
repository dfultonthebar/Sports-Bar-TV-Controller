# Fix React error #31 by ensuring single React instance.
# npm 7+ installs peer deps automatically and dedupes; this is the
# only knob actually needed for the "single React instance" goal.
legacy-peer-deps=false

# Removed (v2.48.4):
#   strict-peer-dependencies=true  — pnpm-only option; npm warns "Unknown project config"
#   dedupe=true                    — pnpm-only option; npm warns "Unknown project config"
# Both produced the spammy warnings on every npm invocation while doing nothing.
# npm dedupes by default during install; pnpm has separate semantics.

# Use exact versions to prevent version conflicts
save-exact=false

# Ensure clean installs
prefer-offline=false
