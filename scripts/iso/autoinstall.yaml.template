#cloud-config
# Sports Bar TV Controller — Ubuntu 24.04 LTS Noble autoinstall configuration
#
# This is the v3.1 architecture: stock Ubuntu Server 24.04.4 ISO + subiquity
# autoinstall + curtin. Replaces the ~430-line hand-rolled disk-installer.sh
# that hit 7 bug iterations on 2026-05-27. Canonical's curtin handles every
# gap we were chasing: GPT+bios_boot+EFI partitioning, kernel install +
# initramfs regen, GRUB embed for both BIOS+UEFI, fstab UUIDs, etc.
#
# The {{UBUNTU_PASSWORD_HASH}} placeholder gets filled at build time by
# build-autoinstall-iso.sh via `openssl passwd -6`.

autoinstall:
  version: 1

  # v2.54.92: update=false — true makes subiquity BLOCK on the
  # "checking for updates" screen waiting for operator confirmation.
  # We pin to whatever subiquity ships in the stock 24.04.4 ISO.
  refresh-installer:
    update: false

  # Explicit empty = fully automated. Default is also [] but Grok + research
  # agent both recommend setting it explicitly for clarity / safety.
  interactive-sections: []

  locale: en_US.UTF-8

  keyboard:
    layout: us
    variant: ""

  timezone: America/Chicago

  # Wildcard DHCP via netplan `match:` glob. Hand-rolled installer
  # hardcoded the LIVE ISO's NIC name and broke when installed system
  # had a different NIC name (different hardware path). The match
  # form is the recommended netplan idiom (one entry covers any en*).
  network:
    version: 2
    ethernets:
      primary-nic:
        match:
          name: "en*"
        dhcp4: true

  # v2.54.95: dropped geoip:true — was hanging the install for 30+ min
  # trying to resolve mirror.country.ubuntu.com via geoip lookup before
  # finally falling through to offline-install. Hardcoded primary mirror
  # avoids the resolution attempt entirely. fallback still kicks in if
  # the NUC has no internet at install time (USB-only install case).
  apt:
    fallback: offline-install
    primary:
      - arches: [default]
        uri: http://archive.ubuntu.com/ubuntu
    disable_components: []
    preserve_sources_list: false

  # Identity: ubuntu/ubuntu, hostname sports-bar-controller. Operator
  # can change hostname AFTER install via the location-setup-wizard
  # (first-boot-fresh.sh invokes it). v3.1.0 keeps the install 100%
  # unattended for smoke-test reliability — no interactive-sections.
  identity:
    realname: 'Sports Bar TV Controller'
    username: ubuntu
    password: '{{UBUNTU_PASSWORD_HASH}}'
    hostname: sports-bar-controller

  ssh:
    install-server: true
    allow-pw: true
    # No authorized-keys — Tailscale will be added on first-boot.

  # Direct layout: use the largest disk with GPT + bios_boot + EFI +
  # ext4 root. Curtin auto-sizes everything correctly. No more manual
  # parted incantations + missing bios_boot partitions.
  storage:
    layout:
      name: direct
      match:
        size: largest

  # Minimal extra packages. The first-boot service installs the heavy
  # stuff (node, ollama, etc) so we keep the install ISO small.
  packages:
    - openssh-server
    - curl
    - wget
    - git
    - sqlite3
    - ca-certificates
    - gnupg
    - lsb-release
    - net-tools
    - iputils-ping
    - iproute2
    - parted
    - dosfstools
    - e2fsprogs

  # Late-commands run in the INSTALLER environment with the target
  # filesystem mounted at /target. Use `curtin in-target -- <cmd>` to
  # run a command inside the chroot.
  late-commands:
    # Set ubuntu password again explicitly (some autoinstall builds drop it)
    - echo 'ubuntu:ubuntu' | curtin in-target -- chpasswd

    # Sudoers nopasswd for ubuntu user (matches operator's fleet convention)
    - 'curtin in-target -- bash -c "echo ''%sudo ALL=(ALL) NOPASSWD:ALL'' > /etc/sudoers.d/ubuntu-nopasswd && chmod 440 /etc/sudoers.d/ubuntu-nopasswd"'

    # Copy our first-boot-fresh.sh from the ISO into the target system.
    # build-autoinstall-iso.sh placed it at /cdrom/sports-bar/.
    - cp /cdrom/sports-bar/first-boot-fresh.sh /target/usr/local/bin/sports-bar-first-boot.sh
    - chmod +x /target/usr/local/bin/sports-bar-first-boot.sh

    # Install the first-boot systemd unit so it runs on first real boot.
    - cp /cdrom/sports-bar/sports-bar-first-boot.service /target/etc/systemd/system/
    - curtin in-target -- systemctl enable sports-bar-first-boot.service

    # Create the data directory with correct ownership
    - curtin in-target -- mkdir -p /home/ubuntu/sports-bar-data
    - curtin in-target -- chown ubuntu:ubuntu /home/ubuntu/sports-bar-data

    # Strip quiet+splash from GRUB cmdline so operators see boot output
    # on tty1 instead of a black splash screen (no plymouth assumption).
    - 'curtin in-target -- sed -i ''s/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT=""/'' /etc/default/grub'
    - curtin in-target -- update-grub

  # After install completes, reboot into the installed system.
  # The first-boot service will then clone + build + start PM2.
  shutdown: reboot
