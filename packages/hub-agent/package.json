{
  "name": "@sports-bar/hub-agent",
  "version": "1.0.0",
  "description": "Per-location telemetry agent — polls local APIs, HMAC-signs, pushes to the SBCC hub",
  "main": "./src/index.ts",
  "types": "./src/types.ts",
  "private": true,
  "bin": {
    "sbcc-hub-agent": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./hmac": {
      "types": "./src/hmac.ts",
      "default": "./src/hmac.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "type-check": "tsc --noEmit",
    "dry-run": "tsx src/index.ts --dry-run --once"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  }
}
